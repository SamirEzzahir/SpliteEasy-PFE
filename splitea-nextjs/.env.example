# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env.local and adjust. RULE: every NEXT_PUBLIC_* var is read by the
# BROWSER (runs on your machine), so it must use localhost / 127.0.0.1 — never
# the Docker hostname "backend". Use "backend" ONLY in BACKEND_PROXY_TARGET, and
# only when Next.js itself runs inside Docker. Read at startup, not hot-reloaded.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (BROWSER). Leave EMPTY so HTTP goes through the Next.js
# /api proxy (avoids CORS). Set to a full public URL only in production.
NEXT_PUBLIC_API_URL=http://backend:8000

# Proxy target for /api, used by next.config.mjs when NEXT_PUBLIC_API_URL is empty.
# Server-side only.
#   • Local dev (npm run dev):    http://127.0.0.1:8800
#   • Docker (Next in container): http://backend:8000
BACKEND_PROXY_TARGET=http://backend:8000

# WebSocket base for group chat (BROWSER). WS can't use the /api proxy, so it
# hits the backend directly — must be a host the browser can reach. Leave EMPTY
# to auto-derive from the page host (see wsBaseUrl in lib/api/client.ts).
#   • Local dev:  ws://127.0.0.1:8800
#   • Docker:     ws://127.0.0.1:8000   (backend published on host port 8000)
NEXT_PUBLIC_WS_URL=ws://backend:8000