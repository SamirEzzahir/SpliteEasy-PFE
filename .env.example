# ─────────────────────────────────────────────────────────────────────────────
# SplitEasy — root environment (Docker Compose)
# Copy to `.env` (same folder as docker-compose.yml) and adjust as needed.
# Docker Compose automatically reads this file for ${VAR} substitution.
# NEVER commit the real `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=spliteasy_db
POSTGRES_PORT=5432

# --- Backend (FastAPI) --------------------------------------------------------
# Host port for the backend container (it always listens on 8000 internally).
BACKEND_PORT=8000
# Secret used to sign JWTs — CHANGE THIS in any real deployment.
JWT_SECRET=change-me-in-production
# Seed the demo dataset (login: demo / demo) on first startup. 1 = on, 0 = off.
# Idempotent: only seeds once, then no-ops.
SEED_DEMO=1

# --- Web (Next.js) ------------------------------------------------------------
WEB_PORT=3000
