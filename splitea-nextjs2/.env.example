# Backend API base URL.
# - Leave empty (or unset) to use the Next.js dev-time proxy at /api → http://127.0.0.1:8000
# - Set to a full URL in production, e.g. https://api.spliteasy.example.com
NEXT_PUBLIC_API_URL=

# The proxy target used by `next.config.mjs` when NEXT_PUBLIC_API_URL is empty.
# Only consulted at build time. Override if your backend runs elsewhere locally.
BACKEND_PROXY_TARGET=http://127.0.0.1:8000
